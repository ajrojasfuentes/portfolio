---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="404 — Not Found">
  <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; text-align: center;">
    <h1 style="font-family: 'Geist Mono', monospace; font-size: 96px; color: var(--color-text-muted); margin: 0;">404</h1>
    <p style="font-family: 'Geist', sans-serif; font-size: 18px; color: var(--color-text-secondary); margin-top: 16px;">
      Page not found. Return to <a href="/" style="color: var(--color-text-link); text-decoration: none;">portfolio</a>.
    </p>
  </div>
</BaseLayout>
