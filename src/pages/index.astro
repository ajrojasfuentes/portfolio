---
import IDELayout from "@/layouts/IDELayout.astro";
---

<IDELayout title="Andres Rojas Fuentes — Portfolio" section="home">
  <div style="padding: 48px 0;">
    <h1 style="font-family: 'Geist Mono', monospace; font-size: 52px; line-height: 1.1; color: var(--color-text-primary); letter-spacing: 0.05em;">
      AJ ROJAS FUENTES
    </h1>
    <p style="font-family: 'Geist', sans-serif; font-size: 16px; color: var(--color-text-secondary); margin-top: 16px; max-width: 600px; line-height: 1.7;">
      Data Automation & AI Engineer · Computer Engineer · Scientific Researcher
    </p>
    <p style="font-family: 'Geist', sans-serif; font-size: 16px; color: var(--color-text-secondary); margin-top: 24px;">
      Portfolio initialization complete. Phase 0: Foundation & Tooling deployed.
    </p>
  </div>
</IDELayout>
