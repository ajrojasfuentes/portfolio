# Environment Variables
# Copy this file to .env and fill in the values

# Server-only: Resend API key for contact form email delivery
# Get yours at: https://resend.com
RESEND_API_KEY=

# Public: Full site URL (used for OG images and sitemap)
PUBLIC_SITE_URL=https://ajrojasfuentes.dev

# Public: Google Analytics ID (optional)
PUBLIC_GA_ID=
